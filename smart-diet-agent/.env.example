# 应用配置文件示例
# 复制此文件为 .env 并填写实际值

# 应用设置
APP_NAME=Smart Diet Agent
APP_VERSION=1.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_diet
DB_USER=admin
DB_PASSWORD=your_password_here

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# API配置
API_HOST=0.0.0.0
API_PORT=8000

# 前端配置
FRONTEND_PORT=8501

# 大语言模型配置
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=  # 如果使用自定义API地址，请取消注释并设置

# 日志配置
LOG_LEVEL=INFO

# JWT配置（如需要认证）
# JWT_SECRET_KEY=your_jwt_secret_key
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
